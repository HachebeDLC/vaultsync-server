# Copy this file to .env and fill in your values before running docker-compose.
# Generate a strong secret with: python3 -c "import secrets; print(secrets.token_hex(32))"

# --- Security ---
VAULTSYNC_SECRET=

# --- Database (app connection, mirrors POSTGRES_* below) ---
DB_HOST=db
DB_NAME=vaultsync
DB_USER=vaultsync
DB_PASS=

# --- PostgreSQL container (docker-compose) ---
POSTGRES_PASSWORD=
POSTGRES_DB=vaultsync
POSTGRES_USER=vaultsync

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS (comma-separated origins, or * for open) ---
VAULTSYNC_CORS_ORIGINS=*

# --- RomM integration (optional) ---
ROMM_URL=
ROMM_API_KEY=